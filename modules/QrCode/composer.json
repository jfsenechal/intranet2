{
    "name": "acmarche/qrcode",
    "description": "qrcode and travel expense management module for AcMarche",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "AcMarche",
            "email": "info@acmarche.be"
        }
    ],
    "require": {
        "php": "^8.5",
        "filament/filament": "^5.0",
        "illuminate/contracts": "^12.0|^13.0",
        "simplesoftwareio/simple-qrcode": "^4.2"
    },
    "autoload": {
        "psr-4": {
            "AcMarche\\QrCode\\": "src/",
            "AcMarche\\QrCode\\Database\\Factories\\": "database/factories/",
            "AcMarche\\QrCode\\Database\\Seeders\\": "database/seeders/",
            "AcMarche\\QrCode\\Tests\\": "tests"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AcMarche\\QrCode\\Providers\\QrCodeServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
