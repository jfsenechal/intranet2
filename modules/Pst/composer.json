{
    "name": "acmarche/pst",
    "description": "PST - Programme Stratégique Transversal",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "AcMarche",
            "email": "info@acmarche.be"
        }
    ],
    "require": {
        "php": "^8.5",
        "filament/filament": "^5.0",
        "illuminate/contracts": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "AcMarche\\Pst\\": "src/",
            "AcMarche\\Pst\\Database\\Factories\\": "database/factories/",
            "AcMarche\\Pst\\Database\\Seeders\\": "database/seeders/",
            "AcMarche\\Pst\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AcMarche\\Pst\\Providers\\PstServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
