{
    "name": "acmarche/mailing-list",
    "description": "MailingList ",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "AcMarche",
            "email": "info@acmarche.be"
        }
    ],
    "require": {
        "php": "^8.5",
        "filament/filament": "^5.0",
        "illuminate/contracts": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "AcMarche\\MailingList\\": "src/",
            "AcMarche\\MailingList\\Database\\Factories\\": "database/factories/",
            "AcMarche\\MailingList\\Database\\Seeders\\": "database/seeders/",
            "AcMarche\\MailingList\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AcMarche\\MailingList\\Providers\\MailingListServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
