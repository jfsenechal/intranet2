{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "codewithdennis/larament",
    "type": "project",
    "description": "Larament is a time-saving starter kit to quickly launch Laravel 13.x projects. It includes FilamentPHP 5.x pre-installed and configured, along with additional tools and features to streamline your development workflow.",
    "keywords": [
        "laravel",
        "framework",
        "filamentphp",
        "starter-kit",
        "larament"
    ],
    "license": "MIT",
    "repositories": [
        {
            "name": "filament",
            "type": "composer",
            "url": "https://packages.filamentphp.com/composer"
        },
        {
            "type": "path",
            "url": "./modules/Ad"
        },
        {
            "type": "path",
            "url": "./modules/App"
        },
        {
            "type": "path",
            "url": "./modules/Courrier"
        },
        {
            "type": "path",
            "url": "./modules/Document"
        },
        {
            "type": "path",
            "url": "./modules/EmailManagement"
        },
        {
            "type": "path",
            "url": "./modules/Mileage"
        },
        {
            "type": "path",
            "url": "./modules/News"
        },
        {
            "type": "path",
            "url": "./modules/MailingList"
        },
        {
            "type": "path",
            "url": "./modules/Publication"
        },
        {
            "type": "path",
            "url": "./modules/QrCode"
        },
        {
            "type": "path",
            "url": "./modules/Hrm"
        },
        {
            "type": "path",
            "url": "./modules/Pst"
        },
        {
            "type": "path",
            "url": "./modules/Security"
        },
        {
            "type": "path",
            "url": "./modules/Agent"
        },
        {
            "type": "path",
            "url": "./modules/WhoIsWho"
        }
    ],
    "require": {
        "php": "^8.5",
        "ext-pdo": "*",
        "acmarche/ad": "*@dev",
        "acmarche/agent": "*@dev",
        "acmarche/app": "*@dev",
        "acmarche/courrier": "*@dev",
        "acmarche/document": "*@dev",
        "acmarche/email-management": "*@dev",
        "acmarche/hrm": "*@dev",
        "acmarche/mailing-list": "*@dev",
        "acmarche/mileage": "*@dev",
        "acmarche/news": "*@dev",
        "acmarche/pst": "*@dev",
        "acmarche/publication": "*@dev",
        "acmarche/qrcode": "*@dev",
        "acmarche/security": "*@dev",
        "acmarche/who-is-who": "*@dev",
        "chrome-php/chrome": "^1.15",
        "directorytree/imapengine-laravel": "^v1.2.1",
        "directorytree/ldaprecord-laravel": "^v4.0.0",
        "filament/filament": "^5.0",
        "filament/spatie-laravel-media-library-plugin": "^5.0",
        "intervention/validation": "^4.6",
        "laravel/framework": "^13.0",
        "laravel/nightwatch": "^1.24",
        "laravel/sanctum": "^4.0",
        "laravel/scout": "^10.23",
        "laravel/tinker": "^3.0",
        "meilisearch/meilisearch-php": "^1.16",
        "nunomaduro/essentials": "^1.2",
        "psy/psysh": "^0.12.19",
        "secondnetwork/blade-tabler-icons": "^3.31",
        "simplesoftwareio/simple-qrcode": "^4.2",
        "spatie/browsershot": "^5.2.3",
        "spatie/laravel-pdf": "^2.1.1",
        "spatie/laravel-sluggable": "^3.8",
        "stechstudio/filament-impersonate": "^4.0",
        "symfony/process": "^7.4"
    },
    "require-dev": {
        "driftingly/rector-laravel": "^2.2",
        "fakerphp/faker": "^1.23",
        "filament/blueprint": "^2.1",
        "fruitcake/laravel-debugbar": "^4.0",
        "larastan/larastan": "^3.0",
        "laravel/boost": "^2.0",
        "laravel/pail": "^1.2.2",
        "laravel/pao": "^1.0.6",
        "laravel/pint": "^1.13",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest": "^v4.3.0",
        "pestphp/pest-plugin-browser": "v4.0.3",
        "pestphp/pest-plugin-faker": "^v4.0.0",
        "pestphp/pest-plugin-laravel": "^v4.0.0",
        "pestphp/pest-plugin-livewire": "^v4.0.1",
        "phpunit/phpunit": "^12.5.8",
        "rector/rector": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/Helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan app:welcome",
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi",
            "@php artisan db:seed --ansi",
            "npm install",
            "npm install playwright@latest",
            "npx playwright install",
            "npm run build",
            "@php cleanup.php"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "pest": "./vendor/bin/pest --parallel",
        "rector": "./vendor/bin/rector process --ansi",
        "pint": "./vendor/bin/pint",
        "phpstan": "./vendor/bin/phpstan analyse",
        "review": [
            "@pint",
            "@rector",
            "@phpstan",
            "@pest"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "beta",
    "prefer-stable": true
}
